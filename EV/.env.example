# =============================================================================
# Frontend environment (Vite). Copy to `.env.local` for local dev, and set the
# same variables in Vercel Project Settings → Environment Variables for prod.
# =============================================================================

# Backend API base URL. The vite plugin replaces every literal
# `http://localhost:8080` in the source with this value at build time, so all
# axios calls are routed correctly without editing any .vue file.
VITE_API_URL=https://your-backend.example.com

# (Optional) explicit media base — only needed if plate-log images are served
# from a different host than the API. Otherwise images load via /images/** on VITE_API_URL.
# VITE_MEDIA_BASE_URL=https://your-backend.example.com

# Per-zone MJPEG stream base URLs (set to fixed public endpoints — Cloudflare
# named tunnel, nginx reverse proxy, etc.). Empty value renders a placeholder.
VITE_STREAM_A01=
VITE_STREAM_A02=
VITE_STREAM_B01=
VITE_STREAM_B02=
